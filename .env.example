# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# ---------------------------------------------------------------------------
# Database (PostgreSQL — we recommend Neon: https://neon.tech, free tier)
# ---------------------------------------------------------------------------
# DATABASE_URL = pooled connection (what the app uses at runtime).
# DIRECT_URL   = direct connection (what `prisma db push` / `migrate` uses).
# Neon gives you both in its dashboard — copy them as-is.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Secret used by NextAuth to sign session cookies / JWTs.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""

# Optional: Google OAuth credentials.
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: OpenAI key for AI features (summarize tasks, suggest priorities).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
